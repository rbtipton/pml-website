<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Research | Performance Materials Lab | UNC Charlotte</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --navy:       #0b1929;
    --navy-mid:   #142036;
    --navy-light: #1e3050;
    --gold:       #c8963e;
    --gold-light: #e8b86d;
    --cream:      #f4efe6;
    --cream-dim:  #ddd5c3;
    --white:      #ffffff;
    --text-muted: rgba(244,239,230,0.55);
    --border:     rgba(200,150,62,0.2);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--navy);
    color: var(--cream);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ===== NAV ===== */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 48px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(11,25,41,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--border);
  }
  .nav-logo { display: flex; flex-direction: column; gap: 1px; }
  .nav-logo .lab-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px; font-weight: 600;
    color: var(--gold-light); letter-spacing: 0.03em; line-height: 1;
  }
  .nav-logo .institution {
    font-size: 10px; font-weight: 400;
    color: var(--text-muted); letter-spacing: 0.12em; text-transform: uppercase;
  }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--cream-dim); text-decoration: none; transition: color 0.2s;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--gold-light); }

  /* ===== PAGE HERO ===== */
  .page-hero {
    padding: 140px 48px 80px;
    background: var(--navy-mid);
    position: relative;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,150,62,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,150,62,0.035) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
  }
  .page-hero-content { position: relative; max-width: 1160px; margin: 0 auto; }
  .page-eyebrow {
    display: flex; align-items: center; gap: 12px;
    font-size: 10px; font-weight: 500; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 20px;
  }
  .page-eyebrow::before {
    content: ''; display: block; width: 24px; height: 1px; background: var(--gold);
  }
  .page-hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(48px, 6vw, 76px);
    font-weight: 600; line-height: 1.05; color: var(--white);
    margin-bottom: 20px;
  }
  .page-hero h1 em { font-style: italic; color: var(--gold-light); }
  .page-hero-sub {
    font-size: 17px; font-weight: 300; color: var(--text-muted);
    max-width: 640px; line-height: 1.75; margin-bottom: 48px;
  }
  .program-tabs {
    display: flex; gap: 2px;
  }
  .tab-btn {
    padding: 12px 24px;
    background: rgba(200,150,62,0.06);
    border: 0.5px solid var(--border);
    color: var(--text-muted);
    font-family: 'Jost', sans-serif;
    font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; cursor: pointer;
    transition: all 0.2s; text-decoration: none; display: inline-block;
  }
  .tab-btn:hover { background: rgba(200,150,62,0.12); color: var(--cream); }
  .tab-btn.active {
    background: var(--gold); color: var(--navy); border-color: var(--gold);
  }

  /* ===== UTILITY ===== */
  .container { max-width: 1160px; margin: 0 auto; padding: 0 48px; }
  section { padding: 88px 0; }

  .section-label {
    display: flex; align-items: center; gap: 12px;
    font-size: 10px; font-weight: 500; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 20px;
  }
  .section-label::before { content: ''; display: block; width: 24px; height: 1px; background: var(--gold); }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 600; color: var(--white); line-height: 1.1;
    margin-bottom: 16px;
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px; border: 0.5px solid var(--gold);
    color: var(--gold-light); font-family: 'Jost', sans-serif;
    font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none; transition: background 0.2s;
  }
  .btn-ghost:hover { background: rgba(200,150,62,0.1); }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px; background: var(--gold);
    color: var(--navy); font-family: 'Jost', sans-serif;
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none; transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--gold-light); }

  /* ===== OVERVIEW STATS ===== */
  .overview-stats {
    background: var(--navy);
    border-bottom: 0.5px solid var(--border);
  }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-left: 0.5px solid var(--border);
  }
  .stat-cell {
    padding: 44px 36px;
    border-right: 0.5px solid var(--border);
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
  }
  .stat-cell-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 52px; font-weight: 600; color: var(--gold-light); line-height: 1;
    margin-bottom: 8px;
  }
  .stat-cell-label {
    font-size: 11px; font-weight: 400; color: var(--text-muted);
    letter-spacing: 0.06em; line-height: 1.5;
  }

  /* ===== PROGRAM SECTIONS ===== */

  /* BAM */
  .program-bam { background: var(--navy-mid); }

  .program-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .program-layout.reverse { direction: rtl; }
  .program-layout.reverse > * { direction: ltr; }

  .program-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 120px; font-weight: 400;
    color: rgba(200,150,62,0.07);
    line-height: 1;
    margin-bottom: -20px;
    user-select: none;
  }

  .program-text h2 { margin-bottom: 24px; }
  .program-text p {
    font-size: 15px; font-weight: 300; color: var(--text-muted);
    line-height: 1.85; margin-bottom: 18px;
  }
  .program-text p strong { color: var(--cream); font-weight: 500; }

  .finding-block {
    background: var(--navy-light);
    border-left: 3px solid var(--gold);
    padding: 20px 24px;
    margin: 28px 0;
  }
  .finding-block p {
    font-size: 14px !important;
    font-style: italic;
    color: var(--cream-dim) !important;
    margin: 0 !important;
  }
  .finding-label {
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 8px;
  }

  .program-meta {
    margin-top: 32px;
    padding-top: 28px;
    border-top: 0.5px solid var(--border);
    display: flex; flex-direction: column; gap: 14px;
  }
  .meta-row { display: flex; gap: 12px; align-items: baseline; }
  .meta-key {
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold);
    min-width: 120px; flex-shrink: 0;
  }
  .meta-val { font-size: 14px; font-weight: 300; color: var(--text-muted); }
  .meta-val strong { color: var(--cream); font-weight: 500; }

  /* Visual panel */
  .program-visual {
    position: sticky;
    top: 100px;
  }

  .visual-frame {
    background: var(--navy-light);
    border: 0.5px solid var(--border);
    padding: 40px;
    position: relative;
    overflow: hidden;
  }
  .visual-frame::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--gold);
  }

  .diagram-title {
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 28px;
  }

  /* BAM crystal diagram */
  .bam-diagram { text-align: center; padding: 16px 0; }
  .bam-diagram svg { width: 100%; max-width: 320px; height: auto; }

  /* Ocean map */
  .ocean-visual { text-align: center; }
  .ocean-visual svg { width: 100%; height: auto; }

  /* Particle visual */
  .particle-visual { position: relative; }
  .particle-visual svg { width: 100%; height: auto; }

  .visual-caption {
    font-size: 12px; font-weight: 300; color: var(--text-muted);
    margin-top: 20px; line-height: 1.6; text-align: center;
  }

  /* tags */
  .tag-row { display: flex; flex-wrap: wrap; gap: 6px; margin: 24px 0; }
  .tag {
    font-size: 10px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 4px 10px;
    border: 0.5px solid rgba(200,150,62,0.4); color: var(--gold);
  }

  /* separating rule between programs */
  .program-divider {
    height: 0.5px;
    background: var(--border);
    max-width: 1160px;
    margin: 0 auto;
  }

  /* ===== ACTIVE GRANTS ===== */
  .grants-section { background: var(--navy-light); }
  .grants-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 52px;
  }
  .grant-card {
    background: var(--navy-mid);
    padding: 36px 32px;
    border-top: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .grant-card:hover { border-top-color: var(--gold); }
  .grant-badge {
    display: inline-flex;
    padding: 4px 10px;
    border: 0.5px solid rgba(200,150,62,0.4);
    font-size: 10px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 20px;
  }
  .grant-card h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; font-weight: 600; color: var(--white);
    line-height: 1.25; margin-bottom: 12px;
  }
  .grant-card p {
    font-size: 13px; font-weight: 300; color: var(--text-muted);
    line-height: 1.7; margin-bottom: 24px;
  }
  .grant-detail { display: flex; flex-direction: column; gap: 8px; }
  .grant-row { display: flex; justify-content: space-between; align-items: baseline; }
  .grant-key {
    font-size: 10px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-muted);
  }
  .grant-val { font-size: 13px; font-weight: 400; color: var(--cream-dim); }

  /* ===== PATENTS ===== */
  .patents-section { background: var(--navy-mid); }
  .patents-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    margin-top: 48px;
  }
  .patent-card {
    background: var(--navy);
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    border-left: 2px solid var(--border);
    transition: border-color 0.2s;
  }
  .patent-card:hover { border-left-color: var(--gold); }
  .patent-num {
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold);
  }
  .patent-card h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 600; color: var(--white); line-height: 1.2;
  }
  .patent-card p {
    font-size: 14px; font-weight: 300; color: var(--text-muted); line-height: 1.75;
  }
  .patent-status {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 500; color: var(--gold-light);
  }
  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold); animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; } 50% { opacity: 0.35; }
  }

  /* ===== SELECT PUBLICATIONS ===== */
  .pubs-section { background: var(--navy); }
  .pubs-list { margin-top: 48px; display: flex; flex-direction: column; gap: 2px; }
  .pub-item {
    background: var(--navy-mid);
    padding: 28px 32px;
    display: flex;
    gap: 28px;
    align-items: flex-start;
    transition: background 0.2s;
  }
  .pub-item:hover { background: var(--navy-light); }
  .pub-year {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px; font-weight: 400; color: var(--gold);
    min-width: 52px; line-height: 1; padding-top: 2px;
  }
  .pub-body { flex: 1; }
  .pub-title {
    font-size: 15px; font-weight: 500; color: var(--white);
    line-height: 1.4; margin-bottom: 6px; text-decoration: none;
    display: block;
  }
  .pub-title:hover { color: var(--gold-light); }
  .pub-authors {
    font-size: 13px; font-weight: 300; color: var(--text-muted); margin-bottom: 6px;
  }
  .pub-journal {
    font-size: 12px; font-style: italic; color: var(--gold);
    font-family: 'Cormorant Garamond', serif;
  }
  .pub-type {
    font-size: 10px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 4px 10px;
    border: 0.5px solid var(--border); color: var(--text-muted);
    flex-shrink: 0; height: fit-content; margin-top: 4px;
  }

  /* ===== FIELD CAMPAIGNS ===== */
  .field-section { background: var(--navy-light); }
  .campaigns-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 52px;
  }
  .campaign-card {
    background: var(--navy-mid);
    padding: 36px 28px;
    border-top: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .campaign-card:hover { border-top-color: var(--gold); }
  .campaign-date {
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 12px;
  }
  .campaign-card h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; font-weight: 600; color: var(--white);
    line-height: 1.2; margin-bottom: 10px;
  }
  .campaign-card p {
    font-size: 13px; font-weight: 300; color: var(--text-muted); line-height: 1.7;
    margin-bottom: 20px;
  }
  .campaign-sites { display: flex; flex-direction: column; gap: 6px; }
  .site-row {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 300; color: var(--cream-dim);
  }
  .site-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }

  /* ===== FOOTER ===== */
  footer {
    background: var(--navy);
    padding: 64px 0 40px;
    border-top: 0.5px solid var(--border);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px; margin-bottom: 56px;
  }
  .footer-brand {}
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 600; color: var(--gold-light); margin-bottom: 6px;
  }
  .footer-inst {
    font-size: 11px; font-weight: 300; letter-spacing: 0.08em;
    color: var(--text-muted); margin-bottom: 20px;
  }
  .footer-brand p { font-size: 13px; font-weight: 300; color: var(--text-muted); line-height: 1.7; }
  .footer-col h5 {
    font-size: 10px; font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 20px;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 10px; }
  .footer-col a {
    font-size: 13px; font-weight: 300; color: var(--text-muted);
    text-decoration: none; transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--cream); }
  .footer-bottom {
    padding-top: 32px;
    border-top: 0.5px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-bottom p { font-size: 12px; font-weight: 300; color: var(--text-muted); }

  /* ===== PAGE ANIMATION ===== */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .page-eyebrow { animation: fadeUp 0.5s 0.1s both ease-out; }
  .page-hero h1  { animation: fadeUp 0.6s 0.2s both ease-out; }
  .page-hero-sub { animation: fadeUp 0.5s 0.35s both ease-out; }
  .program-tabs  { animation: fadeUp 0.5s 0.5s both ease-out; }
</style>
</head>
