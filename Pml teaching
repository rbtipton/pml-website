<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Teaching | Performance Materials Lab | UNC Charlotte</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --navy:       #0b1929;
    --navy-mid:   #142036;
    --navy-light: #1e3050;
    --gold:       #c8963e;
    --gold-light: #e8b86d;
    --cream:      #f4efe6;
    --cream-dim:  #ddd5c3;
    --white:      #ffffff;
    --text-muted: rgba(244,239,230,0.55);
    --border:     rgba(200,150,62,0.2);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--navy);
    color: var(--cream);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ===== NAV ===== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 48px; height: 68px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(11,25,41,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--border);
  }
  .nav-logo { display: flex; flex-direction: column; gap: 1px; }
  .nav-logo .lab-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px; font-weight: 600; color: var(--gold-light);
    letter-spacing: 0.03em; line-height: 1;
  }
  .nav-logo .institution {
    font-size: 10px; font-weight: 400; color: var(--text-muted);
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    font-size: 12px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--cream-dim);
    text-decoration: none; transition: color 0.2s;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--gold-light); }

  /* ===== PAGE HERO ===== */
  .page-hero {
    padding: 140px 48px 88px;
    background: var(--navy-mid);
    position: relative; overflow: hidden;
  }
  .page-hero-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(200,150,62,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,150,62,0.035) 1px, transparent 1px);
    background-size: 80px 80px; pointer-events: none;
  }
  .page-hero-content { position: relative; max-width: 1160px; margin: 0 auto; }

  .hero-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
  }

  .page-eyebrow {
    display: flex; align-items: center; gap: 12px;
    font-size: 10px; font-weight: 500; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 20px;
  }
  .page-eyebrow::before { content: ''; display: block; width: 24px; height: 1px; background: var(--gold); }

  .page-hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(46px, 6vw, 76px); font-weight: 600;
    line-height: 1.05; color: var(--white); margin-bottom: 20px;
  }
  .page-hero h1 em { font-style: italic; color: var(--gold-light); }
  .page-hero-sub {
    font-size: 17px; font-weight: 300; color: var(--text-muted);
    max-width: 520px; line-height: 1.75;
  }

  /* Philosophy pull quote in hero */
  .hero-philosophy {
    border-left: 3px solid var(--gold);
    padding: 28px 32px;
    background: rgba(200,150,62,0.05);
    position: relative;
  }
  .hero-philosophy::before {
    content: '\201C';
    font-family: 'Cormorant Garamond', serif;
    font-size: 80px; font-weight: 400;
    color: rgba(200,150,62,0.2);
    position: absolute; top: -10px; left: 24px;
    line-height: 1;
  }
  .hero-philosophy p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 400; font-style: italic;
    color: var(--cream); line-height: 1.5; margin-bottom: 16px;
    padding-top: 20px;
  }
  .hero-philosophy cite {
    font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gold);
    font-style: normal;
  }

  /* ===== UTILITY ===== */
  .container { max-width: 1160px; margin: 0 auto; padding: 0 48px; }
  section { padding: 88px 0; }

  .section-label {
    display: flex; align-items: center; gap: 12px;
    font-size: 10px; font-weight: 500; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 20px;
  }
  .section-label::before { content: ''; display: block; width: 24px; height: 1px; background: var(--gold); }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 3.5vw, 48px); font-weight: 600;
    color: var(--white); line-height: 1.1; margin-bottom: 16px;
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px; border: 0.5px solid var(--gold);
    color: var(--gold-light); font-family: 'Jost', sans-serif;
    font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none; transition: background 0.2s;
  }
  .btn-ghost:hover { background: rgba(200,150,62,0.1); }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px; background: var(--gold); color: var(--navy);
    font-family: 'Jost', sans-serif; font-size: 11px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none; transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--gold-light); }

  /* ===== PHILOSOPHY PILLARS ===== */
  .philosophy-section { background: var(--navy); }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 52px;
  }

  .pillar-card {
    background: var(--navy-mid);
    padding: 44px 36px;
    border-top: 2px solid transparent;
    transition: border-color 0.25s;
    position: relative; overflow: hidden;
  }
  .pillar-card:hover { border-top-color: var(--gold); }

  .pillar-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 88px; font-weight: 400;
    color: rgba(200,150,62,0.06);
    position: absolute; top: 8px; right: 20px;
    line-height: 1; pointer-events: none; user-select: none;
  }

  .pillar-icon {
    width: 44px; height: 44px;
    border: 1px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold-light); margin-bottom: 24px;
  }
  .pillar-icon svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 1.5; }

  .pillar-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px; font-weight: 600; color: var(--white);
    line-height: 1.2; margin-bottom: 14px;
  }
  .pillar-card p {
    font-size: 14px; font-weight: 300; color: var(--text-muted);
    line-height: 1.8;
  }

  /* ===== COURSE CARDS ===== */
  .courses-section { background: var(--navy-mid); }

  .course-block {
    background: var(--navy);
    margin-bottom: 2px;
    display: grid;
    grid-template-columns: 300px 1fr;
    min-height: 400px;
  }
  .course-block:last-child { margin-bottom: 0; }

  .course-sidebar {
    background: var(--navy-light);
    padding: 48px 36px;
    border-right: 0.5px solid var(--border);
    display: flex; flex-direction: column; justify-content: space-between;
    position: relative; overflow: hidden;
  }
  .course-sidebar::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
    background: var(--gold);
  }

  .course-code {
    font-size: 11px; font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 10px;
  }
  .course-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px; font-weight: 600; color: var(--white);
    line-height: 1.15; margin-bottom: 20px;
  }
  .course-meta-list { display: flex; flex-direction: column; gap: 10px; }
  .course-meta-row { display: flex; flex-direction: column; gap: 2px; }
  .course-meta-key {
    font-size: 9px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold);
  }
  .course-meta-val {
    font-size: 13px; font-weight: 300; color: var(--cream-dim);
  }
  .course-status {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 11px; font-weight: 500; color: var(--gold-light);
    margin-top: 24px;
  }
  .status-dot-live {
    width: 6px; height: 6px; border-radius: 50%; background: var(--gold);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .course-body { padding: 48px 48px; display: flex; flex-direction: column; gap: 36px; }

  .course-description {}
  .course-description p {
    font-size: 15px; font-weight: 300; color: var(--text-muted); line-height: 1.85;
    margin-bottom: 14px;
  }
  .course-description p strong { color: var(--cream); font-weight: 500; }

  /* Topic modules grid */
  .modules-label {
    font-size: 10px; font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 16px;
  }
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .module-chip {
    background: var(--navy-light);
    padding: 14px 16px;
    border-left: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .module-chip:hover { border-left-color: var(--gold); }
  .module-name {
    font-size: 13px; font-weight: 500; color: var(--cream);
    margin-bottom: 3px; line-height: 1.2;
  }
  .module-detail {
    font-size: 11px; font-weight: 300; color: var(--text-muted);
  }

  /* Deliverables row */
  .deliverables-row {
    display: flex; gap: 8px; flex-wrap: wrap;
    padding-top: 24px; border-top: 0.5px solid var(--border);
  }
  .deliverable-badge {
    font-size: 10px; font-weight: 500; letter-spacing: 0.08em;
    padding: 5px 12px;
    border: 0.5px solid rgba(200,150,62,0.35);
    color: var(--gold); text-transform: uppercase;
  }
  .deliverables-label {
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--text-muted);
    align-self: center; margin-right: 4px;
  }

  /* ===== INDUSTRY BRIDGE ===== */
  .bridge-section { background: var(--navy-light); }

  .bridge-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .bridge-text h2 { margin-bottom: 24px; }
  .bridge-text p {
    font-size: 15px; font-weight: 300; color: var(--text-muted);
    line-height: 1.85; margin-bottom: 18px;
  }
  .bridge-text p strong { color: var(--cream); font-weight: 500; }

  .timeline {
    display: flex; flex-direction: column; gap: 0;
    position: relative;
    margin-top: 8px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 20px; top: 0; bottom: 0;
    width: 1px; background: var(--border);
  }

  .timeline-item {
    display: flex; gap: 24px; align-items: flex-start;
    padding: 20px 0;
    border-bottom: 0.5px solid rgba(200,150,62,0.08);
  }
  .timeline-item:last-child { border-bottom: none; }

  .timeline-dot {
    width: 40px; height: 40px; flex-shrink: 0;
    border: 1px solid var(--gold);
    background: var(--navy-mid);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px; font-weight: 600; color: var(--gold);
    position: relative; z-index: 1;
  }

  .timeline-content {}
  .timeline-role {
    font-size: 14px; font-weight: 500; color: var(--cream);
    margin-bottom: 3px;
  }
  .timeline-note {
    font-size: 12px; font-weight: 300; color: var(--text-muted);
    line-height: 1.6;
  }

  .bridge-callout {
    background: var(--navy-mid);
    border: 0.5px solid var(--border);
    border-left: 3px solid var(--gold);
    padding: 28px 28px;
    margin-top: 36px;
  }
  .bridge-callout p {
    font-size: 14px; font-weight: 300;
    color: var(--cream-dim); line-height: 1.75;
    margin: 0 !important;
  }
  .bridge-callout p strong { color: var(--cream) !important; font-weight: 500; }

  /* ===== STUDENT OUTCOMES ===== */
  .outcomes-section { background: var(--navy-mid); }

  .outcomes-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-top: 52px;
    align-items: start;
  }

  .outcomes-panel {
    background: var(--navy);
    padding: 40px 36px;
  }
  .outcomes-panel h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px; font-weight: 600; color: var(--white);
    margin-bottom: 24px; line-height: 1.2;
  }
  .outcome-list { display: flex; flex-direction: column; gap: 14px; }
  .outcome-item {
    display: flex; gap: 14px; align-items: flex-start;
    padding-bottom: 14px;
    border-bottom: 0.5px solid rgba(200,150,62,0.08);
  }
  .outcome-item:last-child { border-bottom: none; padding-bottom: 0; }
  .outcome-marker {
    width: 20px; height: 20px; flex-shrink: 0;
    border: 1px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; font-weight: 600; color: var(--gold);
    margin-top: 2px;
  }
  .outcome-text {
    font-size: 13px; font-weight: 300; color: var(--text-muted);
    line-height: 1.7;
  }
  .outcome-text strong { color: var(--cream); font-weight: 500; }

  /* Tools / instruments table */
  .instruments-panel {
    background: var(--navy);
    padding: 40px 36px;
  }
  .instruments-panel h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px; font-weight: 600; color: var(--white);
    margin-bottom: 24px; line-height: 1.2;
  }
  .instrument-table { width: 100%; border-collapse: collapse; }
  .instrument-table tr { border-bottom: 0.5px solid rgba(200,150,62,0.08); }
  .instrument-table tr:last-child { border-bottom: none; }
  .instrument-table td {
    padding: 12px 0;
    font-size: 13px; font-weight: 300; vertical-align: top;
  }
  .instrument-table td:first-child {
    color: var(--cream); font-weight: 400; padding-right: 16px;
    min-width: 160px;
  }
  .instrument-table td:last-child { color: var(--text-muted); }

  /* ===== GRAD MENTORING ===== */
  .mentoring-section { background: var(--navy); }

  .mentoring-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 52px;
  }
  .mentee-card {
    background: var(--navy-mid);
    padding: 36px 30px;
    border-top: 2px solid transparent;
    transition: border-top-color 0.2s;
  }
  .mentee-card:hover { border-top-color: var(--gold); }

  .mentee-initial {
    width: 48px; height: 48px;
    background: rgba(200,150,62,0.1);
    border: 1px solid rgba(200,150,62,0.3);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; font-weight: 600; color: var(--gold);
    margin-bottom: 20px;
  }

  .mentee-name {
    font-size: 15px; font-weight: 500; color: var(--white); margin-bottom: 4px;
  }
  .mentee-level {
    font-size: 11px; font-weight: 400; letter-spacing: 0.08em;
    color: var(--gold); text-transform: uppercase; margin-bottom: 14px;
  }
  .mentee-card p {
    font-size: 13px; font-weight: 300; color: var(--text-muted);
    line-height: 1.7; margin-bottom: 18px;
  }
  .mentee-tags { display: flex; flex-wrap: wrap; gap: 5px; }
  .mentee-tag {
    font-size: 9px; font-weight: 500; letter-spacing: 0.1em;
    padding: 3px 8px;
    border: 0.5px solid rgba(200,150,62,0.3); color: var(--text-muted);
    text-transform: uppercase;
  }

  /* Undergrad research panel */
  .undergrad-panel {
    background: var(--navy-light);
    border: 0.5px solid var(--border);
    border-left: 3px solid var(--gold);
    padding: 36px 36px;
    margin-top: 2px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .undergrad-panel h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px; font-weight: 600; color: var(--white);
    line-height: 1.2; margin-bottom: 14px;
  }
  .undergrad-panel p {
    font-size: 14px; font-weight: 300; color: var(--text-muted); line-height: 1.75;
  }
  .project-list { display: flex; flex-direction: column; gap: 10px; }
  .project-row {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 300; color: var(--cream-dim);
  }
  .project-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }

  /* ===== CONTACT CTA ===== */
  .cta-section { background: var(--navy-light); }
  .cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 48px;
    padding: 56px 0;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
  }
  .cta-inner h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px; font-weight: 600; color: var(--white); line-height: 1.15;
    margin-bottom: 10px;
  }
  .cta-inner p {
    font-size: 15px; font-weight: 300; color: var(--text-muted); line-height: 1.7;
  }
  .cta-actions { display: flex; gap: 12px; flex-shrink: 0; }

  /* ===== FOOTER ===== */
  footer {
    background: var(--navy);
    padding: 64px 0 40px;
    border-top: 0.5px solid var(--border);
  }
  .footer-grid {
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px; margin-bottom: 56px;
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 600; color: var(--gold-light); margin-bottom: 6px;
  }
  .footer-inst {
    font-size: 11px; font-weight: 300; letter-spacing: 0.08em;
    color: var(--text-muted); margin-bottom: 20px;
  }
  .footer-brand p { font-size: 13px; font-weight: 300; color: var(--text-muted); line-height: 1.7; }
  .footer-col h5 {
    font-size: 10px; font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 20px;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 10px; }
  .footer-col a {
    font-size: 13px; font-weight: 300; color: var(--text-muted);
    text-decoration: none; transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--cream); }
  .footer-bottom {
    padding-top: 32px; border-top: 0.5px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-bottom p { font-size: 12px; font-weight: 300; color: var(--text-muted); }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .page-eyebrow { animation: fadeUp 0.5s 0.1s both ease-out; }
  .page-hero h1  { animation: fadeUp 0.6s 0.2s both ease-out; }
  .page-hero-sub { animation: fadeUp 0.5s 0.35s both ease-out; }
  .hero-philosophy { animation: fadeUp 0.6s 0.45s both ease-out; }

  /* Divider */
  .section-divider {
    height: 0.5px; background: var(--border);
    max-width: 1160px; margin: 0 auto;
  }
</style>
</head>
